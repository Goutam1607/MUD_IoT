{
  "ietf-mud:mud": {
    "mud-version": 1,
    "mud-url": "http://10.211.83.196:5000/mud/temperature_sensor.json",
    "last-update": "2026-07-23T10:00:00+00:00",
    "cache-validity": 48,
    "is-supported": true,
    "systeminfo": "DHT11 Temperature and Humidity Sensor - publishes readings every 10 seconds via MQTT",
    "from-device-policy": {
      "access-lists": {
        "access-list": [
          { "name": "allow-mqtt-outbound" },
          { "name": "allow-https-updates" },
          { "name": "deny-all-other" }
        ]
      }
    },
    "to-device-policy": {
      "access-lists": {
        "access-list": [
          { "name": "allow-mqtt-inbound" },
          { "name": "deny-all-inbound" }
        ]
      }
    },
    "access-lists": {
      "access-list": [
        {
          "name": "allow-mqtt-outbound",
          "aces": {
            "ace": [{
              "name": "mqtt-rule",
              "matches": {
                "ipv4": { "destination-ipv4-network": "10.211.83.196/32" },
                "tcp":  { "destination-port": { "port": 1883 } }
              },
              "actions": { "forwarding": "accept" }
            }]
          }
        },
        {
          "name": "allow-https-updates",
          "aces": {
            "ace": [{
              "name": "https-rule",
              "matches": {
                "tcp": { "destination-port": { "port": 443 } }
              },
              "actions": { "forwarding": "accept" }
            }]
          }
        },
        {
          "name": "deny-all-other",
          "aces": {
            "ace": [{
              "name": "deny-rule",
              "matches": {},
              "actions": { "forwarding": "drop" }
            }]
          }
        },
        {
          "name": "allow-mqtt-inbound",
          "aces": {
            "ace": [{
              "name": "mqtt-inbound-rule",
              "matches": {
                "tcp": { "destination-port": { "port": 1883 } }
              },
              "actions": { "forwarding": "accept" }
            }]
          }
        },
        {
          "name": "deny-all-inbound",
          "aces": {
            "ace": [{
              "name": "deny-inbound-rule",
              "matches": {},
              "actions": { "forwarding": "drop" }
            }]
          }
        }
      ]
    }
  }
}
